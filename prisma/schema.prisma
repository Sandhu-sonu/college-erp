generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id Int @id @default(autoincrement())

  name String

  fatherName String

  mobile String

  course String

  feeStatus String

  createdAt DateTime @default(now())

  fees Fee[]

  semesterRecords SemesterRecord[]
}

model Fee {
  id Int @id @default(autoincrement())

  studentId Int

  amount Float

  paymentDate DateTime @default(now())

  paymentMethod String?

  remarks String?

  receiptNumber String?

  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model SemesterRecord {
  id Int @id @default(autoincrement())

  studentId Int

  semester Int

  subjects String

  totalFee Float?

  paidAmount Float?

  remainingFee Float?

  feeStatus String?

  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
}

model Subject {
  id Int @id @default(autoincrement())

  subjectName String

  courseName String

  semester Int

  subjectType String

  createdAt DateTime @default(now())
}

model User {
  id String @id @default(cuid())

  name String?

  email String @unique

  password String

  createdAt DateTime @default(now())
}

model Inquiry {
  id Int @id @default(autoincrement())

  fullName String

  email String

  mobile String

  course String

  message String

  createdAt DateTime @default(now())
}

model Course {
  id Int @id @default(autoincrement())

  courseName String @unique

  totalFee Float

  duration String?

  createdAt DateTime @default(now())
}
