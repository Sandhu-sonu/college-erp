generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id          Int      @id @default(autoincrement())
  studentName String
  fatherName  String
  course      String
  mobile      String
  feeStatus   String
  createdAt   DateTime @default(now())
}