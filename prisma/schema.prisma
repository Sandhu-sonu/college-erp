generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id          Int      @id @default(autoincrement())
  studentName String
  fatherName  String
  course      String
  mobile      String
  feeStatus   String
  createdAt   DateTime @default(now())
  fees Fee[]
}
model Fee {

  id          Int      @id @default(autoincrement())

  studentId   Int
  amount      Float
  status      String
  paymentDate DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])

}